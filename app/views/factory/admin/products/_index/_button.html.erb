<div
  data-controller="scan"
  data-action="click->scan#report"
  class="button is-rounded is-primary"
  data-report-url="<%= url_for(action: 'scan') %>"
>
  <%= svg_tag 'plus' %>
  <span><%= t('.scan.title') %></span>
</div>
<%= button_to({ action: 'new' }, params: { 'product[taxon_id]': params[:taxon_id] }, class: 'button is-rounded is-info') do %>
  <%= svg_tag 'plus' %>
  <span><%= t('.new.title') %></span>
<% end %>