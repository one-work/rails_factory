<div class="level is-mobile as-bottom">
  <div class="level-left flex-direction-row pl-4">
    <%= link_to({ controller: 'trade/our/carts', action: 'show', id: @cart.id }, class: 'level-item mb-0 right-badge') do %>
      <i class="fa-solid fa-bag-shopping fa-2x"></i>
      <span class="tag is-badge is-danger"><%= @cart.items.count %></span>
    <% end %>
    <div class="level-item pl-4 align-items-baseline">
      <%= @cart.item_amount.to_money.format.html_safe %>
    </div>
  </div>
  <div class="level-right mt-0 pr-4">
    <div class="level-item">
      <%= link_to({ controller: 'trade/our/carts', action: 'show', id: @cart.id }, class: 'button is-small is-primary is-radius') do %>
        <span>去购物车</span>
        <%= svg_tag 'angle-right' %>
      <% end %>
    </div>
  </div>
</div>
