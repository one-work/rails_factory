<% if @production.taxon.customizable %>
  <%= form_with model: @production, url: { action: 'create_dialog' }, id: 'edit_custom' do %>
  <% end %>
  <%= render partial: 'dispatch_modal', locals: { production: @production } %>
  <%= render partial: 'card_component', locals: { production: @production } %>
<% elsif @production.brothers.enabled.count > 1 %>
  <%= form_with model: @production, url: { action: 'dialog' }, id: 'edit_custom' do %>
  <% end %>
  <%= render partial: 'dispatch_modal', locals: { production: @production } %>
  <%= render partial: 'card_brothers', locals: { production: @production } %>
<% else %>
  <%= form_with model: @production, url: { action: 'dialog' }, id: 'edit_custom' do %>
  <% end %>
  <%= render partial: 'dispatch_modal', locals: { production: @production } %>
<% end %>
