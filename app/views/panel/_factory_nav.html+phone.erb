<div class="card as-transparent">
  <div class="card-header">
    <div class="size-7">
      <%= svg_tag 'store' %>
      <span class="text-grey"><%= t('factory.panel.title') %></span>
    </div>
  </div>
  <div class="card-content fixed-grid has-3-cols">
    <div class="grid">
      <%= link_to({ controller: 'factory/panel/factory_taxons' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'folder-tree', class: 'icon is-medium' %>
        <div class="text-grey size-7 mt-1"><%= t('factory.panel.factory_taxons.index.title') %></div>
      <% end %>
      <%= link_to({ controller: 'factory/panel/scenes' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'lightbulb', class: 'icon is-medium' %>
        <div class="text-grey size-7 mt-1"><%= t('factory.panel.scenes.index.title') %></div>
      <% end %>
      <%= link_to({ controller: 'factory/panel/brands' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'copyright', class: 'icon is-medium' %>
        <div class="text-grey size-7 mt-1"><%= t('factory.panel.brands.index.title') %></div>
      <% end %>
    </div>
  </div>
</div>
